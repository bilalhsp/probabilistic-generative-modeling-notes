@article{akaaboune_diffusion-based_2026,
	title = {Diffusion-{Based} {Brain}-to-{Speech} {Synthesis}: {Decoding} {Intracranial} {EEG} into {Natural} {Speech}},
	volume = {3190},
	issn = {1742-6588, 1742-6596},
	shorttitle = {Diffusion-{Based} {Brain}-to-{Speech} {Synthesis}},
	url = {https://iopscience.iop.org/article/10.1088/1742-6596/3190/1/012008},
	doi = {10.1088/1742-6596/3190/1/012008},
	abstract = {Brain-to-speech synthesis aims to restore communication for people who have lost the ability to speak by decoding neural activity directly into intelligible speech. In this paper, we present a diffusion-based framework for reconstructing speech from intracranial EEG (iEEG) recordings. Unlike traditional regression models that map neural signals to acoustic features in a purely deterministic manner, our approach combines a feedforward network that predicts a coarse Mel-spectrogram from iEEG with a conditional diffusion model that iteratively refines this estimate into a high-fidelity spectrogram. We evaluate the method on a publicly available single-word iEEG speech production dataset and compare it against linear and neural regression baselines. The diffusion-enhanced reconstructions achieve high frame-level correlation with ground-truth spectrograms and are perceived as more intelligible and natural in subjective listening tests. These results indicate that integrating probabilistic generative modelling into neural speech decoding is a promising step toward future neural speech prostheses and brain-driven assistive communication technologies.},
	language = {en},
	number = {1},
	urldate = {2026-05-05},
	journal = {Journal of Physics: Conference Series},
	author = {Akaaboune, Fatima Ezzahra and Al-Radhi, Mohammed Salah},
	month = mar,
	year = {2026},
	pages = {012008},
	file = {PDF:C\:\\Users\\ahmedb\\Zotero\\storage\\LDMRXE6M\\Akaaboune and Al-Radhi - 2026 - Diffusion-Based Brain-to-Speech Synthesis Decoding Intracranial EEG into Natural Speech.pdf:application/pdf},
}

