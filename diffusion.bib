@misc{prenger_waveglow_2018,
	title = {{WaveGlow}: {A} {Flow}-based {Generative} {Network} for {Speech} {Synthesis}},
	shorttitle = {{WaveGlow}},
	url = {http://arxiv.org/abs/1811.00002},
	doi = {10.48550/arXiv.1811.00002},
	abstract = {In this paper we propose WaveGlow: a ﬂow-based network capable of generating high quality speech from melspectrograms. WaveGlow combines insights from Glow [1] and WaveNet [2] in order to provide fast, efﬁcient and highquality audio synthesis, without the need for auto-regression. WaveGlow is implemented using only a single network, trained using only a single cost function: maximizing the likelihood of the training data, which makes the training procedure simple and stable. Our PyTorch implementation produces audio samples at a rate of more than 500 kHz on an NVIDIA V100 GPU. Mean Opinion Scores show that it delivers audio quality as good as the best publicly available WaveNet implementation. All code will be made publicly available online [3].},
