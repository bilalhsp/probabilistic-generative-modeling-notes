	keywords = {Computer Science - Computer Vision and Pattern Recognition},
	annote = {Comment: The code of our work is available here: \{{\textbackslash}url\{https://github.com/tyshiwo1/DiM-DiffusionMamba/\}\}},
	file = {Full Text PDF:C\:\\Users\\ahmedb\\Zotero\\storage\\A8VY6ASD\\Teng et al. - 2024 - DiM Diffusion Mamba for Efficient High-Resolution Image Synthesis.pdf:application/pdf;Snapshot:C\:\\Users\\ahmedb\\Zotero\\storage\\Y4PYFCVP\\2405.html:text/html},
