@article{ahmed_deep_2025,
	title = {Deep neural networks explain spiking activity in auditory cortex},
	volume = {21},
	issn = {1553-7358},
	url = {https://journals.plos.org/ploscompbiol/article?id=10.1371/journal.pcbi.1013334},
	doi = {10.1371/journal.pcbi.1013334},
	abstract = {For static stimuli or at gross (∼1-s) time scales, artificial neural networks (ANNs) that have been trained on challenging engineering tasks, like image classification and automatic speech recognition, are now the best predictors of neural responses in primate visual and auditory cortex. It is, however, unknown whether this success can be extended to spiking activity at fine time scales, which are particularly relevant to audition. Here we address this question with ANNs trained on speech audio, and acute multi-electrode recordings from the auditory cortex of squirrel monkeys. We show that layers of trained ANNs can predict the spike counts of multi-units responding to speech audio and to monkey vocalizations at bin widths of 50 ms and below. For some multi-units, the ANNs explain close to all of the explainable variance—much more than traditional spectrotemporal receptive fields, and more than untrained networks. Non-primary neurons tend to be more predictable by deeper layers of the ANNs, but there is much variation by neuron, which would be invisible to coarser recording modalities.},
	language = {en},
	number = {8},
	urldate = {2025-10-01},
	journal = {PLOS Computational Biology},
	publisher = {Public Library of Science},
	author = {Ahmed, Bilal and Downer, Joshua D. and Malone, Brian J. and Makin, Joseph G.},
	month = aug,
	year = {2025},
	keywords = {Action potentials, Artificial neural networks, Auditory cortex, Monkeys, Neuronal tuning, Neurons, Speech, Vocalization},
	pages = {e1013334},
	file = {Full Text PDF:C\:\\Users\\ahmedb\\Zotero\\storage\\C62ULEZ2\\Ahmed et al. - 2025 - Deep neural networks explain spiking activity in auditory cortex.pdf:application/pdf},
}

